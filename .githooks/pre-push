#!/bin/sh
# push 직전 docs/changelog/YYYY-MM.md 맨 위에 이번 push 기록 누적
# 설치: git config core.hooksPath .githooks

set -e

if [ "$CHANGELOG_HOOK_RECURSIVE" = "1" ]; then
  exit 0
fi

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

PYTHON=
if command -v python >/dev/null 2>&1; then
  PYTHON=python
elif command -v py >/dev/null 2>&1; then
  PYTHON=py
else
  echo "pre-push: Python이 필요합니다 (changelog 갱신)."
  echo "       https://www.python.org/downloads/"
  exit 1
fi

commits_before=$(git rev-parse HEAD)

"$PYTHON" "$ROOT/.githooks/lib/update_changelog.py" --apply
status=$?

if [ "$status" -eq 2 ]; then
  echo "pre-push: push할 새 커밋 없음 — changelog 생략"
  exit 0
fi

if [ "$status" -ne 0 ]; then
  exit 1
fi

commits_after=$(git rev-parse HEAD)
if [ "$commits_before" != "$commits_after" ]; then
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "master")
  echo "pre-push: changelog 커밋 follow-up push"
  CHANGELOG_HOOK_RECURSIVE=1 git push --no-verify "$1" "HEAD:${branch}"
fi

echo "pre-push: changelog 반영 완료 — push 계속"
exit 0
